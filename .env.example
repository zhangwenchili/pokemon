# Copy to .env for local development (never commit .env). On Heroku use: heroku config:set KEY=value

# Public URL host for links inside emails (required in production)
# MAILER_HOST=localhost
# MAILER_PROTOCOL=http

# From address (must be allowed by your provider)
# MAILER_FROM="Pokémon <noreply@yourdomain.com>"

# --- SMTP (required together: SMTP_ADDRESS + SMTP_PASSWORD) ---

# SendGrid (Heroku: add SendGrid, then often use user "apikey" and API key as password)
# SMTP_ADDRESS=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER_NAME=apikey
# SMTP_PASSWORD=your_sendgrid_api_key
# SMTP_DOMAIN=yourdomain.com

# Gmail (use a Google "App password", not your normal password)
# SMTP_ADDRESS=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER_NAME=you@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_DOMAIN=gmail.com

# Optional overrides
# SMTP_AUTHENTICATION=plain
# SMTP_ENABLE_STARTTLS_AUTO=true
# SMTP_RAISE_DELIVERY_ERRORS=true

# --- Heroku (use `heroku config:set`; do not put secrets in git) ---
# Heroku Postgres sets DATABASE_URL automatically (no action needed).
# SOLID_QUEUE_IN_PUMA=true   # run Solid Queue inside the web dyno so deliver_later emails run
# MAILER_HOST=your-app.herokuapp.com
# MAILER_FROM="Pokémon <verified-sender@yourdomain.com>"
# Plus SMTP_* above for real email (e.g. SendGrid add-on).
