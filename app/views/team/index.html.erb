<% content_for :title, "My team" %>

<h1 class="h3 mb-2">My team</h1>
<p class="text-muted mb-4">Up to six Pokémon. Same layout as wild Pokémon — open a card for actions.</p>

<% if @instances.empty? %>
  <p class="text-muted">Your team is empty. Move Pokémon from the repo onto your team from an instance page.</p>
<% else %>
  <div class="row g-4">
    <% @instances.each do |instance| %>
      <%= render "shared/instance_card", instance: instance %>
    <% end %>
  </div>
<% end %>
