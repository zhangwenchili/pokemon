<% content_for :title, "Sign in" %>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <h1 class="h3 mb-4">Sign in</h1>
    <p class="text-muted">Enter your username and password to continue.</p>

    <% if @login_error.present? %>
      <div class="alert alert-danger"><%= @login_error %></div>
    <% end %>

    <%= form_with url: login_path, method: :post, local: true, class: "card shadow-sm p-4" do %>
      <div class="mb-3">
        <%= label_tag :username, "Username", class: "form-label" %>
        <%= text_field_tag :username, params[:username], class: "form-control", required: true, autocomplete: "username" %>
      </div>
      <div class="mb-3">
        <%= label_tag :password, "Password", class: "form-label" %>
        <%= password_field_tag :password, nil, class: "form-control", required: true, autocomplete: "current-password" %>
      </div>
      <%= submit_tag "Sign in", class: "btn btn-primary w-100" %>
    <% end %>

    <p class="mt-3 text-center text-muted">
      New here?
      <%= link_to "Create an account", register_path %>
    </p>
  </div>
</div>
