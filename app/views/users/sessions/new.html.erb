<% content_for :title, "Sign in" %>

<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <h1 class="h3 mb-4">Sign in</h1>
    <p class="text-muted">Enter your username and password to continue.</p>

    <% if alert.present? %>
      <div class="alert alert-danger"><%= alert %></div>
    <% end %>

    <%= form_with model: resource, scope: resource_name, url: user_session_path, local: true, class: "card shadow-sm p-4" do |f| %>
      <div class="mb-3">
        <%= f.label :username, class: "form-label" %>
        <%= f.text_field :username, autofocus: true, class: "form-control", required: true, autocomplete: "username" %>
      </div>
      <div class="mb-3">
        <%= f.label :password, class: "form-label" %>
        <%= f.password_field :password, class: "form-control", required: true, autocomplete: "current-password" %>
      </div>
      <%= f.submit "Sign in", class: "btn btn-primary w-100" %>
    <% end %>

    <p class="mt-3 text-center text-muted">
      New here?
      <%= link_to "Create an account", new_user_registration_path %>
    </p>
  </div>
</div>
