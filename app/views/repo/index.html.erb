<% content_for :title, "Repo" %>

<h1 class="h3 mb-2">Repo</h1>
<p class="text-muted mb-4">Pokémon you own that are not on your team. Open a card to move one to the team.</p>

<% if @instances.empty? %>
  <p class="text-muted">Your repo is empty. Catch wild Pokémon or move some from your team.</p>
<% else %>
  <div class="row g-4">
    <% @instances.each do |instance| %>
      <%= render "shared/instance_card", instance: instance %>
    <% end %>
  </div>
  <%= render "shared/pagy_bootstrap", pagy: @pagy %>
<% end %>
